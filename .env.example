# Скопируйте в .env и заполните перед запуском docker compose.
#
# Сгенерировать сильный секрет:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Или:
#   openssl rand -base64 48

# Секрет для подписи сессионных cookie. ОБЯЗАТЕЛЬНО уникальный и секретный.
PUTEVOY_SESSION_SECRET=replace-with-random-48-chars-from-secrets-token-urlsafe

# Опционально: API-ключ Яндекс.Геокодера для автоопределения расстояний.
# Получить можно на https://developer.tech.yandex.ru/services/3
# Если оставить пустым, расстояния можно вводить вручную.
YANDEX_GEOCODER_API_KEY=
